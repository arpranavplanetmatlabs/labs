{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MatResOps",
  "version": "0.1.0",
  "identifier": "com.matresops.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devtools": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MatResOps — AI Research Operator",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "python",
          "cmd": "python",
          "args": true
        }
      ]
    }
  }
}
